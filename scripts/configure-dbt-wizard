#!/usr/bin/env bash
set -euo pipefail

project_dir="${1:-$(pwd)}"
dbt_path="${DBT_WIZARD_DBT_PATH:-$HOME/.local/bin/dbt}"
deferral_mode="${DBT_WIZARD_DEFERRAL_MODE:-wizard}"
deferral_target="${DBT_WIZARD_DEFERRAL_TARGET:-prd}"
config_dir="$HOME/.dbt/wizard"
config_file="$config_dir/config.toml"
project_config_file="$config_dir/wizard_config.toml"
anthropic_model="${DBT_WIZARD_ANTHROPIC_MODEL:-claude-opus-4-7}"
openai_model="${DBT_WIZARD_OPENAI_MODEL:-gpt-5.5}"

toml_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s' "$value"
}

append_if_missing() {
  local file="$1"
  local marker="$2"
  local body="$3"

  if [[ -f "$file" ]] && grep -Fq "$marker" "$file"; then
    return
  fi

  mkdir -p "$(dirname "$file")"
  if [[ -s "$file" ]]; then
    printf '\n' >>"$file"
  fi
  printf '%s\n' "$body" >>"$file"
}

ensure_top_level_key() {
  local file="$1"
  local key="$2"
  local value="$3"

  if [[ -f "$file" ]] && grep -Eq "^${key}[[:space:]]*=" "$file"; then
    return
  fi

  mkdir -p "$(dirname "$file")"
  if [[ -s "$file" ]]; then
    local tmp_file
    tmp_file="$(mktemp)"
    {
      printf '%s = "%s"\n\n' "$key" "$(toml_escape "$value")"
      cat "$file"
    } >"$tmp_file"
    mv "$tmp_file" "$file"
  else
    printf '%s = "%s"\n' "$key" "$(toml_escape "$value")" >"$file"
  fi
}

project_key="$(toml_escape "$project_dir")"
dbt_path_value="$(toml_escape "$dbt_path")"
now="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"

mkdir -p "$config_dir"

append_if_missing \
  "$config_file" \
  "[projects.\"$project_key\"]" \
  "[projects.\"$project_key\"]
trust_level = \"trusted\""

if [[ ! -f "$project_config_file" ]]; then
  printf 'version = 1\n' >"$project_config_file"
fi

project_body="[projects.\"$project_key\"]
onboarded_at = \"$now\"
path = \"$dbt_path_value\"

[projects.\"$project_key\".deferral]
mode = \"$deferral_mode\""

if [[ "$deferral_mode" != "disabled" ]]; then
  project_body="$project_body
target = \"$(toml_escape "$deferral_target")\""
fi

append_if_missing \
  "$project_config_file" \
  "[projects.\"$project_key\"]" \
  "$project_body"

if command -v wizard >/dev/null 2>&1; then
  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    ensure_top_level_key "$config_file" "model" "$anthropic_model"
    printf '%s' "$ANTHROPIC_API_KEY" | wizard providers set-key anthropic >/dev/null
    wizard providers enable anthropic >/dev/null
  elif [[ -n "${OPENAI_API_KEY:-}" ]]; then
    ensure_top_level_key "$config_file" "model" "$openai_model"
    printf '%s' "$OPENAI_API_KEY" | wizard providers set-key openai >/dev/null
    wizard providers enable openai >/dev/null
  elif [[ ! -f "$config_dir/provider-auth.json" ]]; then
    printf '%s\n' "dbt Wizard provider setup skipped: set ANTHROPIC_API_KEY or OPENAI_API_KEY as a Codespaces secret, then stop and restart the codespace." >&2
  fi
fi

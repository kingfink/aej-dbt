#!/usr/bin/env python3

import os
import shlex
import subprocess
import sys
from collections.abc import Mapping
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent


def build_modal_command(
    args: list[str],
    *,
    env: Mapping[str, str] = os.environ,
) -> list[str]:
    dbt_args = args or ["build"]
    command = [
        "uv",
        "run",
        "modal",
        "run",
        "app.py",
        "--cmd",
        shlex.join(dbt_args),
    ]
    options = [
        ("--target", env.get("AEJ_DBT_TARGET", "")),
        ("--dbt-user", env.get("AEJ_DBT_USER") or env.get("DBT_USER", "")),
        (
            "--pr-number",
            env.get("AEJ_DBT_PR_NUMBER") or env.get("PR_NUMBER", ""),
        ),
    ]
    for option, value in options:
        if value:
            command.extend([option, value])
    return command


def main() -> int:
    return subprocess.run(build_modal_command(sys.argv[1:]), cwd=ROOT).returncode


if __name__ == "__main__":
    raise SystemExit(main())
